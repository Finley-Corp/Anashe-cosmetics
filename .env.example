# Neon PostgreSQL (pooled URL is fine for the app; `npm run db:seed` uses TCP via `pg` and strips `channel_binding`)
# If seed times out on WSL, try Neon’s "direct" connection string or ensure outbound TCP 5432 is allowed.
DATABASE_URL=

# ImageKit server-side uploads (never expose the private key to the browser)
IMAGEKIT_PRIVATE_KEY=

# Optional: public key for client-side widgets only
IMAGEKIT_PUBLIC_KEY=

# Optional: protect POST /api/upload-image in production
# UPLOAD_SECRET=
